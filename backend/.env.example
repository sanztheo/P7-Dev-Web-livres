PORT=4000
# 'development' en local, 'production' en déploiement (évite la verbosité des erreurs Express).
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/mon-vieux-grimoire
JWT_SECRET=replace_with_a_long_random_secret
# Origine autorisée pour les requêtes CORS (origine du frontend en production). '*' par défaut.
CORS_ORIGIN=*
